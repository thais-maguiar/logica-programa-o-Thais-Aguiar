    public static boolean respostaCorreta(int pergunta, String resposta) {
        return (pergunta == 1 && resposta.equals("B")) ||
               (pergunta == 2 && resposta.equals("C")) ||
               (pergunta == 3 && resposta.equals("D")) ||
               (pergunta == 4 && resposta.equals("C")) ||
               (pergunta == 5 && resposta.equals("E"));
    }

    public static String respostaCertaTexto(int pergunta) {
        switch (pergunta) {
            case 1: return "B";
            case 2: return "C";
            case 3: return "D";
            case 4: return "C";
            case 5: return "E";
            default: return "";
        }
    }

