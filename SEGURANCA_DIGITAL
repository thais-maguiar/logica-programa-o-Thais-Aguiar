            System.out.println();

            switch (numeroPergunta) {
                case 1:
                    System.out.println("Em Criptolândia, os cidadãos guardam seus segredos em baús mágicos.");
                    System.out.println("O que esses baús representam?");
                    System.out.println("A) Jogos instalados");
                    System.out.println("B) Dados pessoais");
