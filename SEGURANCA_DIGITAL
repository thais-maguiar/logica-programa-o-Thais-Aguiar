                    break;

                case 2:
                    System.out.println("Você recebe uma mensagem estranha dizendo que ganhou um prêmio,");
                    System.out.println("mas para receber precisa clicar em um link e digitar sua senha.");
                    System.out.println("O que isso pode ser?");
                    System.out.println("A) Uma mensagem confiável");
                    System.out.println("B) Um backup dos seus arquivos");
                    System.out.println("C) Um golpe para roubar seus dados");
                    System.out.println("D) Uma senha segura");
                    System.out.println("E) Uma proteção do computador");
                    break;

                case 3:
                    System.out.println("Lord Vírus, vindo de Hackerion, tenta entrar usando links desconhecidos.");
                    System.out.println("O que o jovem aprendiz deve fazer?");
                    System.out.println("A) Clicar rapidamente");
                    System.out.println("B) Compartilhar com todos os amigos");
                    System.out.println("C) Ignorar os riscos");
                    System.out.println("D) Evitar clicar e verificar se é confiável");
                    System.out.println("E) Colocar sua senha no link");
                    break;

                case 4:
                    System.out.println("Os firewalls mágicos cercam Criptolândia.");
                    System.out.println("Qual é a função deles?");
                    System.out.println("A) Deixar o castelo mais bonito");
                    System.out.println("B) Guardar cavalos");
                    System.out.println("C) Controlar e bloquear acessos perigosos");
                    System.out.println("D) Criar músicas");
                    System.out.println("E) Apagar fotos antigas");
                    break;

                case 5:
                    System.out.println("Para proteger os baús de Dados Pessoais, qual senha seria mais segura?");
                    System.out.println("A) 123456");
                    System.out.println("B) senha123");
                    System.out.println("C) meu_nome");
                    System.out.println("D) data de nascimento");
                    System.out.println("E) Uma senha longa com letras, números e símbolos");
                    break;
            }

            System.out.println();
            System.out.print("Digite a alternativa correta (A, B, C, D ou E): ");
            resposta = scanner.nextLine().trim().toUpperCase();

            while (!resposta.equals("A") && !resposta.equals("B") && !resposta.equals("C")
                    && !resposta.equals("D") && !resposta.equals("E")) {
                System.out.print("Opção inválida. Digite A, B, C, D ou E: ");
                resposta = scanner.nextLine().trim().toUpperCase();
            }

            if (respostaCorreta(numeroPergunta, resposta)) {
                pontuacao++;
                limparTelaFake();
                telaAcerto(numeroPergunta);
            } else {
                erros++;
                limparTelaFake();
                telaErro(numeroPergunta, respostaCertaTexto(numeroPergunta));
            }

            System.out.println();
            System.out.println("Pontuação atual: " + pontuacao + " de 5");
            System.out.println("Ameaça de Hackerion: " + erros + " de 5");
            esperarEnter(scanner);

            numeroPergunta++;
        }

        limparTelaFake();
        resultadoFinal(pontuacao, erros);
